# PostgreSQL
POSTGRES_DB=igar
POSTGRES_USER=igar
POSTGRES_PASSWORD=igar_dev_password
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
DATABASE_URL=postgresql://igar:igar_dev_password@postgresql:5432/igar
DB_NAME=igar
DB_USER=igar
DB_PASSWORD=igar_dev_password
DB_HOST=postgresql
DB_PORT=5432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Django
DJANGO_SETTINGS_MODULE=igar.settings.development
SECRET_KEY=change-me-in-real-env
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Frontend
VITE_API_URL=http://localhost/api/v1
VITE_WS_URL=ws://localhost/ws/

# Sentry
SENTRY_DSN=

# AWS / tusd
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1
